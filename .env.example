# === OpenScribe Environment Variables ===

# Database (default: SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/openscribe.db

# File storage
UPLOAD_DIR=./data/uploads
PROCESSED_DIR=./data/processed

# --- STT Engine API Keys ---

# Whisper: Hugging Face token (for speaker diarization with pyannote, gated models)
HUGGING_FACE_TOKEN=

# CLOVA Speech API
CLOVA_SPEECH_INVOKE_URL=
CLOVA_SPEECH_SECRET=

# NVIDIA Riva server address
RIVA_SERVER=localhost:50051

# Whisper model settings
WHISPER_MODEL_ID=openai/whisper-large-v3
WHISPER_DEVICE=auto

# --- LLM Settings (for meeting notes generation) ---
# Default = local OpenAI-compatible /v1 server (vLLM or Ollama). No cloud key needed.
LLM_BASE_URL=http://localhost:8001/v1
LLM_MODEL=gemma-3-4b-it
# (optional) cloud / alternative providers
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Hugging Face token for gated model downloads (Gemma, pyannote). Used by docker compose.
HF_TOKEN=
